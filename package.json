{
  "name": "impulse-analyzer",
  "version": "0.1.0",
  "description": "Know what breaks before it breaks. Dependency graph + impact analysis for 5 languages.",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "impulse": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "action.yml",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
