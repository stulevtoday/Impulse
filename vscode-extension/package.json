{
  "name": "impulse-vscode",
  "displayName": "Impulse",
  "description": "Know what breaks before it breaks. Live dependency impact analysis.",
  "version": "0.1.0",
  "publisher": "stulevtoday",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Programming Languages", "Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/stulevtoday/Impulse"
  },
  "contributes": {
    "commands": [
      {
        "command": "impulse.showImpact",
        "title": "Impulse: Show Impact of Current File"
      },
      {
        "command": "impulse.showDependencies",
        "title": "Impulse: Show Dependencies"
      },
      {
        "command": "impulse.showDependents",
        "title": "Impulse: Show Dependents (Who Imports This?)"
      },
      {
        "command": "impulse.showHealth",
        "title": "Impulse: Show Project Health"
      },
      {
        "command": "impulse.restartDaemon",
        "title": "Impulse: Restart Daemon"
      }
    ],
    "configuration": {
      "title": "Impulse",
      "properties": {
        "impulse.daemonPort": {
          "type": "number",
          "default": 4096,
          "description": "Port of the Impulse daemon"
        },
        "impulse.showImpactOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Show impact analysis notification when saving a file"
        },
        "impulse.cliPath": {
          "type": "string",
          "default": "",
          "description": "Path to the impulse CLI binary (leave empty to use npx impulse-analyzer)"
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "npm run build -- --watch",
    "package": "npm run build && npx @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.28.0",
    "typescript": "^5.7.3"
  }
}
